# Telegram Bot Token (Get it from @BotFather)
BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Bot Owner's numeric Telegram User ID (e.g. 12345678)
# Replace with your actual user ID
BOT_OWNER_ID=YOUR_TELEGRAM_USER_ID

# Database Configuration
# For SQLite (default):
DATABASE_URL=sqlite+aiosqlite:///bot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Redis Configuration (For anti-flood, caching, rate limits)
# If empty or not set, bot will fall back to local in-memory storage.
REDIS_URL=redis://localhost:6379/0

# Admin Logs Channel ID (Optional but recommended)
# Send detailed audit logs to this channel (must add bot to this channel first)
LOGS_CHANNEL_ID=-1001234567890
